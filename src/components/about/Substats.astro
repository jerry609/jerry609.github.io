---
import { socialLinks, type iconsType } from 'astro-pure/types'
import { Icon } from 'astro-pure/user'

interface SubstatsItem {
  platform: string
  icon: (typeof socialLinks)[number]
  color?: string
  link?: string
  text: string
  api?: string
  count?: number
}

type Props = {
  stats: SubstatsItem[]
}

const { stats } = Astro.props as Props
---

<div class='grid grid-cols-1 gap-3 rounded-xl border p-2 sm:grid-cols-2 sm:p-3'>
  {
    stats.map(({ link, platform, icon, color, count, text, api }) => (
      <a
        class='group text-muted-foreground no-underline'
        href={link}
        target='_blank'
        rel='noopener noreferrer'
      >
        <div class='flex items-center gap-3 rounded-lg border border-transparent px-3 py-2 transition-all hover:border-border hover:bg-muted'>
          {icon && <Icon name={icon as iconsType} color={color} />}
          <div class='flex-1 text-foreground transition-colors group-hover:text-primary'>
            {platform}
          </div>
          {api || count !== undefined ? (
            <div class='flex items-center gap-1.5' data-substats-api={api}>
              <samp data-substats-count>{count ?? '...'}</samp>
              <span class='text-sm font-normal'>{text}</span>
            </div>
          ) : (
            <span class='text-sm font-normal'>{text}</span>
          )}
        </div>
      </a>
    ))
  }
</div>
<script is:inline>
  async function loadSubstats() {
    const items = document.querySelectorAll('[data-substats-api]')

    await Promise.all(
      Array.from(items).map(async (item) => {
        const api = item.getAttribute('data-substats-api')
        const countEl = item.querySelector('[data-substats-count]')
        if (!api || !countEl) return

        try {
          const response = await fetch(`https://api.swo.moe/stats/${api}`)
          const data = await response.json()
          if (!response.ok || data.failed) {
            throw new Error(data.message || `HTTP ${response.status}`)
          }
          countEl.textContent = String(data.count)
        } catch (error) {
          console.warn(`Substats unavailable for ${api}:`, error)
          countEl.textContent = 'N/A'
        }
      })
    )
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadSubstats, { once: true })
  } else {
    loadSubstats()
  }

  document.addEventListener('swup:contentReplaced', loadSubstats)
</script>
<div class='mt-2 text-right text-sm'>
  Display real-time; powered by <a
    class='text-muted-foreground'
    href='http://github.com/spencerwooo/substats'
    target='_blank'
    rel='noopener noreferrer'>Substats</a
  >
</div>
